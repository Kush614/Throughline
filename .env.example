# XTrace Memory — the single source of truth for NeverZero workspace memory.
# Copy to .env.local (gitignored) and fill in. Get these from app.xtrace.ai → Settings → API Keys.
XTRACE_API_KEY=xtk_...
XTRACE_ORG_ID=org_...
# Optional — only set if you were given a non-default API host.
# Defaults to https://api.production.xtrace.ai
# XTRACE_BASE_URL=
